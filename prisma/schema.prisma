generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Producto {
  id          Int      @id @default(autoincrement())
  nombre      String
  precio_usd  Float
  
  // ¡LA MAGIA DE LA GALERÍA! 
  // Cambiamos "imagen String" por "imagenes String[]" (Los corchetes significan que ahora acepta un arreglo/lista de varios links)
  imagenes    String[] 
  
  stock       Int      @default(0)
}

// ¡NUEVA TABLA PARA EL PANEL DE ADMINISTRACIÓN!
model Orden {
  id               Int      @id @default(autoincrement())
  clienteNombre    String
  clienteTelefono  String
  metodoPago       String
  referencia       String
  totalPagado      Float
  
  // El estado inicial siempre será Pendiente hasta que tu hermana revise su cuenta
  estado           String   @default("Pendiente") // Podrá cambiar a "Aprobada" o "Rechazada"
  
  // Guardamos todo el carrito en formato JSON para saber exactamente qué camisas descontar del stock
  detalleCarrito   Json     
  
  fechaCreacion    DateTime @default(now())
}